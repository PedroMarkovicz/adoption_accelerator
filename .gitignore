# ──────────────────────────────────────────────
#  Data — raw, intermediate & output
# ──────────────────────────────────────────────
# Raw source files (downloaded from Kaggle / external sources)
# Note: `dir/*` + `!dir/.gitkeep` is necessary because git won't descend
# into a directory that is itself fully ignored, making negation rules
# inside it unreachable.
data/raw/*
!data/raw/.gitkeep
# Intermediate pipeline outputs
data/processed/*
!data/processed/.gitkeep
data/cleaned/*
!data/cleaned/.gitkeep
data/features/*
!data/features/.gitkeep
data/output/*
!data/output/.gitkeep
# Submission files
data/submissions/*
!data/submissions/.gitkeep

# Common data file formats
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npz
*.npy
*.sqlite
*.db
*.arrow
*.csv.gz
*.csv.bz2
*.csv.xz
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.7z
*.rar

# ──────────────────────────────────────────────
#  ML artefacts
# ──────────────────────────────────────────────
artifacts/*
!artifacts/.gitkeep
!artifacts/models/
artifacts/models/*
!artifacts/models/.gitkeep
*.joblib
*.safetensors
*.onnx
*.pt
*.pth
*.bin
*.ckpt

# ──────────────────────────────────────────────
#  Reports (auto-generated)
# ──────────────────────────────────────────────
reports/*
!reports/.gitkeep
!reports/figures/
!reports/metrics/
reports/figures/eda_images/*
!reports/figures/eda_images/.gitkeep
reports/figures/eda_tabular/*
!reports/figures/eda_tabular/.gitkeep
reports/figures/eda_text/*
!reports/figures/eda_text/.gitkeep
reports/metrics/*
!reports/metrics/.gitkeep

